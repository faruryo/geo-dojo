# Supabase (Transaction Pooler URL - port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — 新 API キー方式 (2025年〜)
# Dashboard > Project Settings > API > API Keys から取得
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # 旧: ANON_KEY

# サーバー側のみ使用（絶対に NEXT_PUBLIC_ を付けないこと）
SUPABASE_SECRET_KEY=sb_secret_...                          # 旧: SERVICE_ROLE_KEY

# Google Maps JavaScript API（クライアント側 — モードD 地図背景用）
# Cloud Console で HTTP referrer 制限必須（http://localhost:* + 本番ドメイン）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# e-Stat API（政府統計の総合窓口、市区町村人口データ取得用）— サーバー側のみ
# https://www.e-stat.go.jp/api/ で登録して取得
E_STAT_APP_ID=...
